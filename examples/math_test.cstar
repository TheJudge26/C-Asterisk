import math

func main() {
    var k = 0.0
    var sum = 0.0
    var iterations = 2 // Even 2 iterations is incredibly accurate

    while (k < iterations) {
        // Simplified Ramanujan-style step
        // (4k) * (1103 + 26390k) / (k!^4 * 396^4k)
        // Note: You'll need to use your 'pow' and 'sqrt' calls here
        var num = 1103.0 + (26390.0 * k)
        var den = pow(396.0, (4.0 * k))
        
        sum = sum + (num / den)
        k = k + 1.0
    }

    var result = (2.0 * sqrt(2.0)) / 9801.0 * sum
    var pi = 1.0 / result
    
    print(pi)
    return 0
}