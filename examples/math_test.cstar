// C* Pi Calculation using Leibniz Formula
import math

func main() {
    var pi = 0.0
    var denominator = 1.0
    var operation = 1.0 // 1.0 for addition, -1.0 for subtraction
    var iterations = 1000000
    var i = 0

    while (i < iterations) {
        // Leibniz step: pi += operation * (4.0 / denominator)
        pi = pi + (operation * (4.0 / denominator))
        
        // Update denominator to the next odd number
        denominator = denominator + 2.0
        
        // Flip the sign for the next term
        operation = operation * -1.0
        
        i = i + 1
    }

    print(pi)
    return 0
}