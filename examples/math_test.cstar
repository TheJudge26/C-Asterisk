func main() {
    var pi = 0.0
    var denom = 1.0
    var sign = 1.0
    var i = 0

    while (i < 5) {
        pi = pi + (sign * (4.0 / denom))
        denom = denom + 2.0
        sign = sign * -1.0
        i = i + 1
    }

    print(pi) // Should output approx 3.339 for 5 iterations
    return 0
}